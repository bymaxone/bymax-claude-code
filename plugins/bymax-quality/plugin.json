{
  "$schema": "https://json.schemastore.org/claude-plugin.json",
  "name": "bymax-quality",
  "displayName": "Bymax Quality",
  "description": "Quality gates and review tooling: /code-review (CRITICAL→LOW severity), /tdd (red-green-refactor), multi-stack tester skill, six specialist sub-agents, and pre/post hooks (secret-scanner blocks credential commits, console-log-scan warns on stale logs).",
  "version": "1.0.0",
  "author": {
    "name": "Maximiliano Salvatti",
    "url": "https://github.com/bymaxone"
  },
  "license": "MIT",
  "homepage": "https://github.com/bymaxone/bymax.claude-code/tree/main/plugins/bymax-quality",
  "keywords": [
    "code-review",
    "tdd",
    "testing",
    "agents",
    "hooks",
    "security",
    "secret-scanner"
  ],
  "commands": ["./commands/code-review.md", "./commands/tdd.md"],
  "agents": [
    "./agents/architect.md",
    "./agents/code-reviewer.md",
    "./agents/database-reviewer.md",
    "./agents/planner.md",
    "./agents/security-reviewer.md",
    "./agents/typescript-reviewer.md"
  ],
  "skills": ["./skills/tester"],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/secret-scanner.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/console-log-scan.sh"
          }
        ]
      }
    ]
  }
}
